# ============================================================================
# Spout — environment. Copy to .env.local and fill in. NEVER commit real values.
# The app runs on the web with NONE of these set (demo path + on-device redaction
# + regex baseline all work). Each secret is an env-var seam: the moment it exists,
# the matching real capability turns on. See each block for what it unlocks.
# ============================================================================

# --- Qwen Cloud (Alibaba Model Studio / DashScope International) --------------
# Unlocks: the AI leak-map — VL statement read, descriptor un-masking, silent-
# pattern detection, cancellation drafting, retention negotiation.
# Get a PLAIN sk- key (NOT sk-sp-) at https://home.qwencloud.com/api-keys
DASHSCOPE_API_KEY=
# Base URL is fixed for the intl endpoint; override only if Alibaba changes it.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- Google OAuth (opt-in "send the escape from your own inbox") -------------
# Unlocks: Gate 2 real send + reply-thread reading via the user's own Gmail,
# and trial-deadline reminders on their Calendar. Everything else works without.
# Create a Desktop/Web OAuth client on any GCP project; enable Gmail + Calendar API.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Where Google returns after consent. Leave blank in dev (derived from the request
# origin). Set explicitly in production, e.g. https://your-host/api/gmail/callback
GOOGLE_OAUTH_REDIRECT_URI=

# --- Session signing ---------------------------------------------------------
# Signs the encrypted cookie that holds the connected-inbox token. Any random
# 32+ char string. A dev default is used if unset (do NOT rely on it in prod).
SPOUT_SESSION_SECRET=

# --- Optional server-side persistence (Alibaba deploy) -----------------------
# The ledger/keep-list/settings persist in the browser by default. To ALSO
# persist server-side (e.g. shared ledger on ECS), point this at a Postgres URL.
# Unset = browser-only persistence (fine for the web/PWA build).
DATABASE_URL=
